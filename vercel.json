{
  "version": 2,
  "builds": [
    { "src": "api/ping.js", "use": "@vercel/node" },
    { "src": "api/volcengine-image.js", "use": "@vercel/node" },
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
